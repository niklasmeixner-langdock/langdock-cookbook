# Required: Microsoft Entra ID (Azure AD) app registration
ENTRA_TENANT_ID=your-tenant-id
ENTRA_CLIENT_ID=your-client-id
ENTRA_CLIENT_SECRET=your-client-secret

# Optional: Server URL (defaults to http://localhost:3333)
# SERVER_URL=http://localhost:3333

# Optional: Port (defaults to 3333)
# PORT=3333
